            "type": "string",
            "description": "店铺ID"
          },
          "discount_name": {
            "type": "string",
            "description": "活动名称"
          },
          "discount_type": {
            "type": "string",
            "description": "折扣类型：percentage/fixed_amount/free_shipping"
          },
          "discount_value": {
            "type": "number",
            "description": "折扣值"
          },
          "minimum_order_amount": {
            "type": "number",
            "description": "最低订单金额"
          },
          "start_date": {
            "type": "string",
            "description": "开始日期"
          },
          "end_date": {
            "type": "string",
            "description": "结束日期"
          },
          "usage_limit": {
            "type": "integer",
            "description": "使用次数限制"
          }
        },
        "required": [
          "store_id",
          "discount_name",
          "discount_type",
          "discount_value"
        ]
      }
    }
  },
