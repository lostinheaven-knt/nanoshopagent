          },
          "discount_name": {
            "type": "string",
            "description": "活动名称"
          },
          "product_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "参与商品ID"
          },
          "discount_type": {
            "type": "string",
            "description": "折扣类型：percentage/fixed_amount/buy_x_get_y"
          },
          "discount_value": {
            "type": "number",
            "description": "折扣值"
          },
          "start_date": {
            "type": "string",
            "description": "开始日期"
          },
          "end_date": {
            "type": "string",
            "description": "结束日期"
          }
        },
        "required": [
          "store_id",
          "discount_name",
          "product_ids",
          "discount_type",
          "discount_value"
        ]
      }
    }
  },
  "post_social_media": {
    "type": "function",
    "function": {
      "name": "post_social_media",
      "description": "发布社交媒体帖子，支持多平台同步发布",
      "parameters": {
        "type": "object",
        "properties": {
          "store_id": {
            "type": "string",
            "description": "店铺ID"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "发布平台：facebook/instagram/tiktok/twitter"
          },
